{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@ageflow/core": ["../../core/src/index.ts"],
      "@ageflow/runner-api": ["../api/src/index.ts"]
    }
  },
  "references": [{ "path": "../../core" }, { "path": "../api" }],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/* [0-9]*.*",
    "src/**/* [0-9]*/**",
    "dist",
    "node_modules"
  ]
}
