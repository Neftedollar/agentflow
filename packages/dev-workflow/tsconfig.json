{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["bun"],
    "noEmit": true
  },
  "include": ["**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/* [0-9]*.*",
    "**/* [0-9]*/**",
    "node_modules",
    "dist"
  ]
}
