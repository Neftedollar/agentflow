{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["bun"],
    "paths": {
      "@ageflow/server": ["../server/src/index.ts"]
    }
  },
  "references": [{ "path": "../server" }],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/**/* [0-9]*.*",
    "src/**/* [0-9]*/**",
    "dist",
    "node_modules"
  ]
}
