{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"],
    "paths": { "@agentflow/core": ["../core/src/index.ts"] }
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/* [0-9]*",
    "src/**/* [0-9]/**",
    "dist",
    "node_modules"
  ]
}
