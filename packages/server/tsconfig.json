{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@ageflow/core": ["../core/src/index.ts"],
      "@ageflow/executor": ["../executor/src/index.ts"]
    }
  },
  "references": [{ "path": "../core" }, { "path": "../executor" }],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/**/* [0-9]*",
    "src/**/* [0-9]/**",
    "dist",
    "node_modules"
  ]
}
