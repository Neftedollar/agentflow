    "@ageflow/mcp-server": "^0.8.0",
    "@ageflow/server": "^0.6.0",
    "@ageflow/server-sqlite": "^0.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "boxen": "^8.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Neftedollar/ageflow.git"
