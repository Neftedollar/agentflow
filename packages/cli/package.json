{
  "name": "@ageflow/cli",
  "version": "0.7.0",
  "description": "CLI for ageflow \u2014 agentwf run / validate / dry-run / init",
  "homepage": "https://github.com/Neftedollar/ageflow/tree/master/packages/cli",
  "type": "module",
  "private": false,
  "bin": {
    "agentwf": "./dist/bin.js"
  },
  "exports": {
    ".": {
